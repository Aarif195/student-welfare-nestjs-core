// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  email       String   @unique
  password    String
  phone       String
  address     String?
  role        Role     @default(student)
  image       String?
  is_verified Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  hostels  Hostel[] // This links to the owner_id in the Hostel model
  bookings Booking[]
  payments Payment[]

  // Notifications
  createdNotifications Notification[]
  readNotifications NotificationRead[]
}

model Hostel {
  id          Int                @id @default(autoincrement())
  owner_id    Int
  owner       User               @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  name        String
  location    String
  description String?
  status      VerificationStatus @default(PENDING)
  rejection_reason String?
  rooms       Room[]
  created_at  DateTime           @default(now())
  updated_at  DateTime           @updatedAt

  // Relation to the resource model
  resources HostelResource[]

  // Notifications
  notifications Notification[]

  @@map("hostels")
}

model HostelResource {
  id         Int          @id @default(autoincrement())
  hostel_id  Int
  file_url   String // The URL of the file (Image, Video, or PDF)
  file_type  ResourceType // Enum to distinguish between IMAGE, VIDEO
  created_at DateTime     @default(now())

  hostel Hostel @relation(fields: [hostel_id], references: [id], onDelete: Cascade)

  @@map("hostel_resources")
}

enum ResourceType {
  IMAGE
  VIDEO
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  student
  hostelOwner
  superadmin
}

model EmailOtp {
  id         Int      @id @default(autoincrement())
  email      String
  otp_code   String
  expires_at DateTime
  createdAt  DateTime @default(now())

  @@index([email])
}

model Room {
  id           Int            @id @default(autoincrement())
  hostel_id    Int
  hostel       Hostel         @relation(fields: [hostel_id], references: [id], onDelete: Cascade)
  room_number  String
  type         String?
  capacity     Int?
  price        Decimal        @db.Decimal(10, 2)
  availability Boolean        @default(true)
  resources    RoomResource[] // Replaces the TEXT[] array
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt

  bookings Booking[]

  @@unique([hostel_id, room_number])
}

model RoomResource {
  id      Int          @id @default(autoincrement())
  url     String
  type    ResourceType // Uses existing enum
  room_id Int
  room    Room         @relation(fields: [room_id], references: [id], onDelete: Cascade)
}

model Booking {
  id               Int       @id @default(autoincrement())
  student_id       Int
  student          User      @relation(fields: [student_id], references: [id], onDelete: Cascade)
  room_id          Int
  room             Room      @relation(fields: [room_id], references: [id], onDelete: Cascade)
  booking_status   String    @default("pending")
  booked_at        DateTime  @default(now())
  start_date       DateTime  @db.Date
  end_date         DateTime  @db.Date
  price            Decimal   @db.Decimal(10, 2)
  rejection_reason String?
  payments         Payment[]

  @@map("bookings")
}

model Payment {
  id             Int       @id @default(autoincrement())
  booking_id     Int          @unique
  booking        Booking   @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  student_id     Int
  student        User      @relation(fields: [student_id], references: [id], onDelete: Cascade)
  amount         Decimal   @db.Decimal(10, 2)
  payment_status String    @default("pending")
  payment_method String?
  reference      String?   @unique
  paid_at        DateTime?
  refund_status  String?   @default("none")

  @@map("payments")
}


model Notification {
  id           Int      @id @default(autoincrement())
  title        String
  message      String
  type         String   // "global" or "hostel"
  
  hostel_id    Int?
  hostel       Hostel?  @relation(fields: [hostel_id], references: [id])
  
  created_by   Int
  author       User     @relation(fields: [created_by], references: [id])
  
  creator_role Role     // This uses your existing Role enum
  createdAt    DateTime @default(now())

  // Relation 
  readBy      NotificationRead[]
}

model NotificationRead {
  id              Int          @id @default(autoincrement())
  notification_id Int
  student_id      Int
  read_at         DateTime     @default(now())

  notification    Notification @relation(fields: [notification_id], references: [id], onDelete: Cascade)
  student         User         @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([notification_id, student_id]) 
}