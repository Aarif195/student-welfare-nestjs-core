// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
    url      = env("DATABASE_URL")

}

model User {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  password  String
  phone     String
  address   String?
  role      Role     @default(student)
  image     String?
  is_verified Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

// Relations
  hostels       Hostel[]     // This links to the owner_id in the Hostel model
}

model Hostel {
  id          Int                @id @default(autoincrement())
  owner_id    Int
  owner       User               @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  name        String
  location    String
  description String?
  status      VerificationStatus @default(PENDING)
  created_at  DateTime           @default(now())
  updated_at  DateTime           @updatedAt

   // Relation to the resource model
    resources   HostelResource[]

  @@map("hostels")
}

model HostelResource {
  id          Int          @id @default(autoincrement())
  hostel_id   Int
  file_url    String       // The URL of the file (Image, Video, or PDF)
  file_type   ResourceType // Enum to distinguish between IMAGE, VIDEO, PDF
  created_at  DateTime     @default(now())

  hostel      Hostel       @relation(fields: [hostel_id], references: [id], onDelete: Cascade)

  @@map("hostel_resources")
}


enum ResourceType {
  IMAGE
  VIDEO
  PDF
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  student
  hostelOwner 
  superadmin
}


model EmailOtp {
  id         Int      @id @default(autoincrement())
  email      String
  otp_code   String
  expires_at DateTime
  createdAt  DateTime @default(now())

  @@index([email])
}

