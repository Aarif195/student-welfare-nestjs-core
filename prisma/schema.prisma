// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
    url      = env("DATABASE_URL")

}

model User {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  password  String
  phone     String
  address   String?
  role      Role     @default(student)
  image     String?
  is_verified Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

// Relations
  hostels       Hostel[]     // This links to the owner_id in the Hostel model
}

model Hostel {
  id          Int                @id @default(autoincrement())
  owner_id    Int
  owner       User               @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  name        String
  location    String
  description String?
  status      VerificationStatus @default(PENDING)
  created_at  DateTime           @default(now())
  updated_at  DateTime           @updatedAt

  // Relation to the new images model
  images      HostelImage[]

  @@map("hostels")
}

model HostelImage {
  id         Int      @id @default(autoincrement())
  hostel_id  Int
  image_url  String   // The URL of the image
  created_at DateTime @default(now())

  // Relation back to the hostel
  hostel     Hostel   @relation(fields: [hostel_id], references: [id], onDelete: Cascade)

  @@map("hostel_images")
}

enum Role {
  student
  hostelOwner 
  superadmin
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model EmailOtp {
  id         Int      @id @default(autoincrement())
  email      String
  otp_code   String
  expires_at DateTime
  createdAt  DateTime @default(now())

  @@index([email])
}

